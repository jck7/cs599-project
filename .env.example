# ═══════════════════════════════════════════════
# LLM 模型底座配置
# ═══════════════════════════════════════════════

# 是否启用真实 LLM（false 时使用规则引擎模拟，无需 API Key）
USE_REAL_LLM=false

# 模型提供方选择：deepseek / mimo / auto（优先 DeepSeek，其次 MiMo）
LLM_PROVIDER=deepseek


# ── MiMo API 配置（备用模型） ──
MIMO_API_KEY=tp-cwpy76xu08jnklqpnhn1nu5p6x06hykubg5t2mnch2x3gnwl
MIMO_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1
MIMO_MODEL_NAME=mimo-v2.5-pro

# ── 通用 LLM 参数 ──
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=2000
LLM_TIMEOUT=60

# ═══════════════════════════════════════════════
# 重试与降级配置
# ═══════════════════════════════════════════════

# LLM 调用失败后重试次数
LLM_MAX_RETRIES=2

# 重试间隔（秒）
LLM_RETRY_DELAY=1.0

# 是否启用降级模式（true 时 API 失败自动切换到本地知识库）
LLM_FALLBACK_ENABLED=true

# ═══════════════════════════════════════════════
# 可观测性（LangSmith）
# ═══════════════════════════════════════════════
LANGSMITH_API_KEY=your_langsmith_key_here
LANGSMITH_TRACING=false
LANGSMITH_PROJECT=cs599-oa-agent

# ═══════════════════════════════════════════════
# Agent 服务配置
# ═══════════════════════════════════════════════
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# ═══════════════════════════════════════════════
# 风险阈值配置
# ═══════════════════════════════════════════════
RISK_LOW_THRESHOLD=30
RISK_MEDIUM_THRESHOLD=60
RISK_HIGH_THRESHOLD=80
AUTO_APPROVE_AMOUNT=1000
MANUAL_REVIEW_AMOUNT=5000
